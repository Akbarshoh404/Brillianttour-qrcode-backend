# ---------------------------------------------------------------------------
# Backend environment variables
# Copy this file to ".env" in the backend/ directory and fill in real values.
# NEVER commit the real ".env" file — it is already listed in .gitignore.
# ---------------------------------------------------------------------------

# Supabase project credentials (Project Settings -> API)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Supabase Storage bucket used to store uploaded PDF files
SUPABASE_STORAGE_BUCKET=pdfs

# Postgres connection string (Project Settings -> Database -> Connection string -> URI)
DATABASE_URL=postgresql://postgres:password@db.your-project-ref.supabase.co:5432/postgres

# Public base URL this API is served from. Used to build permanent QR redirect
# links: {PUBLIC_BASE_URL}/p/{uuid}. Never hardcode a domain in code — this is
# the ONLY place the domain is configured.
# Production value for this project:
PUBLIC_BASE_URL=https://qrcode.brillianttour.uz

# Comma separated list of origins allowed to call this API (CORS).
# Production value for this project:
CORS_ORIGINS=https://docs.brillianttour.uz

# Optional: https://ipgeolocation.io API key used to resolve country/city from
# an IP address when a QR code is scanned. Leave blank to disable geolocation.
IP_GEOLOCATION_API_KEY=

# --- Dashboard login -------------------------------------------------------
# Single shared credential gating the dashboard (view/upload/replace/disable/
# delete documents). Never gates /p/{uuid} or /download/{uuid} — those stay
# public. REQUIRED: the app will refuse logins (500) until both are set.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=
JWT_EXPIRE_MINUTES=10080

# --- Trash -------------------------------------------------------------------
# How many days a deleted document stays recoverable before being purged
# permanently (database row + storage file).
TRASH_RETENTION_DAYS=7

# Environment name, affects logging/debug behaviour: local | staging | production
APP_ENV=production

# Optional: port to bind to. Most PaaS platforms (Render, Railway, Coolify,
# etc.) inject this automatically — only set it manually on a plain VPS.
PORT=8000
